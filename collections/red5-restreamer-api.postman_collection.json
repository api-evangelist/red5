          "name": "Create File Restream Provision",
          "request": {
            "name": "Create File Restream Provision",
            "description": {
              "content": "Creates a provision that restreams a recorded FLV or MP4 file as a pseudo-live stream. The file is played back continuously or on loop, allowing pre-recorded content to be distributed as a live stream.",
              "type": "text/plain"
            },
            "url": {
