          "request": {
            "name": "Create Rtmp Restream Provision",
            "description": {
              "content": "Creates a provision that configures the Red5 Pro server to push a live ingest stream to one or more external RTMP or RTMPS destinations such as Facebook Live, YouTube Live, or any RTMP-compatible CDN endpoint. Each destination is specified with a stream URL and stream key.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "restreamer",
                "provision.create"
              ],
              "host": [
