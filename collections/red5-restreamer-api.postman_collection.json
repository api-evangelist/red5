  "info": {
    "_postman_id": "6a69ff57-3d68-40a3-a174-394b417887ea",
    "name": "Red5 Pro Restreamer API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Red5 Pro Restreamer API controls live stream retransmission to external RTMP, RTMPS, SRT, and Zixi destinations including social media platforms like Facebook and YouTube. It accepts JSON-based provisions via POST requests to configure push and pull restreaming sessions from a Red5 Pro server. The API supports file-based pseudo-live restreaming of FLV and MP4 files, as well as real-time forwarding of live ingest streams to multiple destinations simultaneously.\n\nContact Support:\n Name: Red5 Support",
      "type": "text/plain"
    }
  }
