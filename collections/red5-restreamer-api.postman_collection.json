                "filerestreamer",
                "provision.create"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "accessToken",
                  "value": "<string>",
                  "description": "(Required) API access token for authentication"
                }
              ],
              "variable": [
